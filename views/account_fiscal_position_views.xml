<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         Vista: account.fiscal.position.form
         Añade la sección "Configuración POS (NCF)" con los campos:
           - pos_invoice_journal_id
           - pos_ncf_type
         ================================================================ -->
    <record id="l10n_do_pos_fiscal_position_form" model="ir.ui.view">
        <field name="name">account.fiscal.position.form.l10n_do_pos</field>
        <field name="model">account.fiscal.position</field>
        <field name="inherit_id" ref="account.view_account_position_form"/>
        <field name="arch" type="xml">

            <!-- Añadimos el grupo POS después del último grupo de la cabecera -->
            <xpath expr="//sheet/group[last()]" position="after">
                <group string="Configuración Punto de Venta (NCF)" name="l10n_do_pos_group"
                       col="2">
                    <field name="pos_invoice_journal_id"
                           options="{'no_create': True, 'no_open': True}"
                           placeholder="Diario por defecto del POS si no se configura"/>
                    <field name="pos_ncf_type"
                           placeholder="Ej: B01, B02, B14, B15"/>
                </group>
            </xpath>

        </field>
    </record>

</odoo>
